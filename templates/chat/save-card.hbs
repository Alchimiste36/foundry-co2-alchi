{{log "Chroniques Oubliées | save card" this}}
<div class="co chat-card roll-card save-card" data-actor-id="{{actorId}}">
  <header class="card-header flexcol">
    <div class="card-item-card">
      {{#if itemImg}}
        <img class="card-item-image" src="{{itemImg}}" alt="{{itemName}}" />
      {{else}}
        <div class="type-card"><label><i class="fa-solid fa-shield-exclamation" data-tooltip="{{localize 'CO.ui.saves'}}" data-tooltip-direction="LEFT"></i></label></div>
      {{/if}}
      <div class="card-item-text">
        <div class="card-item-name">{{#if itemName}}{{itemName}}{{else}}{{flavor}}{{/if}}</div>
        {{#if actionName}}
          <div class="card-item-subtitle">{{actionName}}</div>
        {{/if}}
      </div>
    </div>
  </header>

  <div class="card-content">
    <section class="bloc-result has-target-results">
      <section class="result">
        <div class="difficulty-group">
          <div class="difficulty-icon" data-tooltip="{{localize 'CO.ui.saves'}} : {{getAbilityLabel ability}}" data-tooltip-direction="UP"><i class="fas fa-shield-exclamation"></i></div>
          <div class="difficulty-value display-difficulty" data-tooltip="{{localize 'CO.label.long.difficulty'}}{{#if difficultyFormula}} ({{difficultyFormula}}){{/if}}" data-tooltip-direction="UP">{{difficulty}}</div>
        </div>
      </section>
    </section>
    <section class="targets"></section>
  </div>
</div>
